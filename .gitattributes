
# 自动检测文本文件
* text=auto

# 项目文件 - 当作二进制文件处理，防止任何转换
*.pbxproj binary
*.xcodeproj binary
*.xcworkspace binary
*.xcuserstate binary
*.xcscheme binary

# 确保这些文件使用 LF 换行符
*.sh text eol=lf
*.swift text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# 图片等二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
